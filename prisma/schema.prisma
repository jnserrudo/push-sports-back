model ProductoVariante {
  id_variante          String    @id @default(uuid()) @db.Uuid
  id_producto          String    @db.Uuid
  sku_variante         String?   @unique
  atributos_valores    Json      // {"SABOR": "VAINILLA", "TAMAГғвҖҳO": "1KG"}
  stock_central        Int       @default(0)
  precio_variante      Decimal   @db.Decimal(10, 2) @default(0)  // Precio especГғВӯfico (0 = usar precio del producto)
  activo               Boolean   @default(true)
  fecha_creacion       DateTime  @default(now())
  fecha_actualizacion  DateTime? @updatedAt  // Opcional para permitir migraciГғВіn con datos existentes

  producto             Producto  @relation(fields: [id_producto], references: [id_producto], onDelete: Cascade)
  inventarios          InventarioComercioVariante[]
  movimientos          MovimientoStockVariante[]
  ventas_detalle       VentaDetalleVariante[]

  @@map("PRODUCTOS_VARIANTES")
}

model InventarioComercioVariante {
  id_inventario_var    String   @id @default(uuid()) @db.Uuid
  id_inventario        String   @db.Uuid
  id_variante          String   @db.Uuid
  cantidad_actual      Int      @default(0)
  stock_minimo_alerta  Int      @default(5)
  
  inventario_padre     InventarioComercio @relation(fields: [id_inventario], references: [id_inventario])
  variante             ProductoVariante @relation(fields: [id_variante], references: [id_variante])

  @@unique([id_inventario, id_variante])
  @@map("INVENTARIO_COMERCIO_VARIANTES")
}

model MovimientoStockVariante {
  id_movimiento_var    String   @id @default(uuid()) @db.Uuid
  id_movimiento        String   @db.Uuid
  id_variante          String   @db.Uuid
  cantidad_cambio      Int
  saldo_anterior       Int
  saldo_posterior      Int

  movimiento_padre     MovimientoStock @relation(fields: [id_movimiento], references: [id_movimiento])
  variante             ProductoVariante @relation(fields: [id_variante], references: [id_variante])

  @@map("MOVIMIENTOS_STOCK_VARIANTES")
}

model VentaDetalleVariante {
  id_detalle_var       String   @id @default(uuid()) @db.Uuid
  id_detalle           String   @db.Uuid
  id_variante          String   @db.Uuid
  cantidad             Int
  precio_unitario      Decimal  @db.Decimal(10, 2)

  detalle_padre        VentaDetalle @relation(fields: [id_detalle], references: [id_detalle])
  variante             ProductoVariante @relation(fields: [id_variante], references: [id_variante])

  @@map("VENTAS_DETALLE_VARIANTES")
}

model Evento {
  id_evento        String    @id @default(uuid()) @db.Uuid
  nombre           String
  recompensa_texto String?
  fecha_inicio     DateTime?
  fecha_fin        DateTime?
  activo           Boolean   @default(true)
  created_at       DateTime  @default(now())

  usuarios_captados Usuario[]

  @@map("EVENTOS")
}

// SISTEMA DE RECTIFICACIONES
model SolicitudRectificacion {
  id_solicitud      String    @id @default(uuid()) @db.Uuid
  tipo_entidad      String
  id_entidad        String    @db.Uuid
  id_comercio       String    @db.Uuid
  id_solicitante    String    @db.Uuid
  id_aprobador      String?   @db.Uuid
  estado            String    @default("PENDIENTE")
  motivo            String    @db.Text
  datos_corregidos  String?   @db.Text
  fecha_solicitud   DateTime  @default(now())
  fecha_resolucion  DateTime?
  motivo_rechazo    String?   @db.Text

  @@index([id_comercio])
  @@index([estado])
  @@index([id_solicitante])
  @@map("SOLICITUDES_RECTIFICACION")
}
