generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id_usuario           String    @id @default(uuid()) @db.Uuid
  nombre               String
  apellido             String
  username             String    @unique
  email                String    @unique
  password_hash        String
  id_rol               Int
  id_comercio_asignado String?   @db.Uuid
  activo               Boolean   @default(true)
  
  // Campos de verificaciГғВіn por email
  email_verificado     Boolean   @default(false)
  otp_code             String?
  otp_expira_en        DateTime?
  // Campos para Leads/Eventos
  id_evento_origen     String?   @db.Uuid
  acepta_marketing     Boolean   @default(true)

  rol                  Rol       @relation(fields: [id_rol], references: [id_rol])
  comercio_asignado    Comercio? @relation(fields: [id_comercio_asignado], references: [id_comercio])
  evento_origen        Evento?   @relation(fields: [id_evento_origen], references: [id_evento])

  notificaciones       Notificacion[]
  ventas_procesadas    VentaCabecera[]
  movimientos_autorizados MovimientoStock[]
  auditorias_rastreadas AuditoriaSistema[]
  devoluciones         Devolucion[]
  password_reset_tokens PasswordResetToken[]

  @@map("USUARIOS")
}

model Rol {
  id_rol       Int       @id @default(autoincrement())
  nombre_rol   String
  descripcion  String?

  usuarios     Usuario[]

  @@map("ROLES")
}

model Notificacion {
  id_notificacion String   @id @default(uuid()) @db.Uuid
  id_usuario      String   @db.Uuid
  titulo          String
  mensaje         String   @db.Text
  tipo            String
  leido           Boolean  @default(false)
  fecha_envio     DateTime @default(now())

  usuario         Usuario  @relation(fields: [id_usuario], references: [id_usuario])

  @@map("NOTIFICACIONES")
}

model Producto {
  id_producto           String    @id @default(uuid()) @db.Uuid
  nombre                String
  descripcion           String?   @db.Text
  id_categoria          Int
  id_marca              Int
  id_proveedor          String?   @db.Uuid
  precio_venta_sugerido Decimal   @db.Decimal(10, 2)
  precio_pushsport      Decimal   @default(0) @db.Decimal(10, 2)
  costo_compra          Decimal   @db.Decimal(10, 2)
  imagen_url            String?   @db.Text
  stock_minimo          Int       @default(5)
  stock_central         Int       @default(0)
  atributos             Json?     @default("{}")
  usa_variantes         Boolean   @default(false)
  activo                Boolean   @default(true)

  categoria             Categoria  @relation(fields: [id_categoria], references: [id_categoria])
  marca                 Marca      @relation(fields: [id_marca], references: [id_marca])
  proveedor             Proveedor? @relation(fields: [id_proveedor], references: [id_proveedor])

  inventarios           InventarioComercio[]
  variantes             ProductoVariante[]
  ventas_detalle        VentaDetalle[]
  movimientos           MovimientoStock[]
  devoluciones          Devolucion[]

  @@map("PRODUCTOS")
}

model Categoria {
  id_categoria Int      @id @default(autoincrement())
  nombre       String
  descripcion  String?

  productos    Producto[]

  @@map("CATEGORIAS")
}

model Marca {
  id_marca     Int      @id @default(autoincrement())
  nombre_marca String

  productos    Producto[]

  @@map("MARCAS")
}

model Proveedor {
  id_proveedor     String   @id @default(uuid()) @db.Uuid
  nombre_proveedor String
  telefono         String?
  razon_social     String?
  cuit             String?
  activo           Boolean   @default(true)

  productos        Producto[]

  @@map("PROVEEDORES")
}

model Comercio {
  id_comercio          String   @id @default(uuid()) @db.Uuid
  nombre               String
  id_tipo_comercio     Int
  direccion            String?
  latitud              Decimal? @db.Decimal(10, 8)
  longitud             Decimal? @db.Decimal(11, 8)
  imagen_url           String?
  saldo_acumulado_mili Decimal  @default(0) @db.Decimal(20, 2)
  activo               Boolean  @default(true)

  tipo_comercio        TipoComercio @relation(fields: [id_tipo_comercio], references: [id_tipo_comercio])

  usuarios_asignados   Usuario[]
  inventarios          InventarioComercio[]
  ventas_registradas   VentaCabecera[]
  liquidaciones_cierre Liquidacion[]
  movimientos_stock    MovimientoStock[]
  devoluciones         Devolucion[]

  @@map("COMERCIOS")
}

model TipoComercio {
  id_tipo_comercio Int        @id @default(autoincrement())
  nombre           String
  descripcion      String?

  comercios        Comercio[]

  @@map("TIPOS_COMERCIO")
}

model InventarioComercio {
  id_inventario               String   @id @default(uuid()) @db.Uuid
  id_comercio                 String   @db.Uuid
  id_producto                 String   @db.Uuid
  cantidad_actual             Int      @default(0)
  stock_minimo_alerta         Int      @default(5)
  comision_pactada_porcentaje Decimal  @db.Decimal(5, 2)
  requiere_migracion          Boolean  @default(false)
  usa_desglose_variantes      Boolean  @default(false)

  comercio                    Comercio @relation(fields: [id_comercio], references: [id_comercio])
  producto                    Producto @relation(fields: [id_producto], references: [id_producto])
  variantes                   InventarioComercioVariante[]

  @@unique([id_comercio, id_producto])
  @@map("INVENTARIO_COMERCIO")
}

model TipoMovimiento {
  id_tipo_movimiento    Int      @id @default(autoincrement())
  nombre_movimiento     String
  factor_multiplicador  Int      @default(1)

  movimientos           MovimientoStock[]

  @@map("TIPOS_MOVIMIENTO")
}

model MovimientoStock {
  id_movimiento      String   @id @default(uuid()) @db.Uuid
  id_producto        String   @db.Uuid
  id_comercio        String   @db.Uuid
  id_usuario         String   @db.Uuid
  id_tipo_movimiento Int
  cantidad_cambio    Int
  saldo_anterior     Int
  saldo_posterior    Int
  tiene_desglose_variantes Boolean @default(false)
  fecha_hora         DateTime @default(now())

  // Campos de rectificaciГғВіn
  id_movimiento_origen  String?  @db.Uuid
  motivo_rectificacion  String?  @db.Text

  producto           Producto @relation(fields: [id_producto], references: [id_producto])
  comercio           Comercio @relation(fields: [id_comercio], references: [id_comercio])
  usuario            Usuario  @relation(fields: [id_usuario], references: [id_usuario])
  tipo_movimiento    TipoMovimiento @relation(fields: [id_tipo_movimiento], references: [id_tipo_movimiento])
  variantes          MovimientoStockVariante[]
  movimiento_origen     MovimientoStock?  @relation("RectMovimiento", fields: [id_movimiento_origen], references: [id_movimiento])
  rectificaciones_mov   MovimientoStock[] @relation("RectMovimiento")

  @@map("MOVIMIENTOS_STOCK")
}

model VentaCabecera {
  id_venta         String   @id @default(uuid()) @db.Uuid
  id_comercio      String   @db.Uuid
  id_usuario       String   @db.Uuid
  id_liquidacion   String?  @db.Uuid
  total_venta      Decimal  @db.Decimal(10, 2)
  metodo_pago      String
  fecha_hora       DateTime @default(now())

  // Campos de rectificaciГғВіn
  tipo_venta            String   @default("VENTA")  // VENTA | ANULACION | RECTIFICACION
  id_venta_origen       String?  @db.Uuid
  motivo_rectificacion  String?  @db.Text

  comercio         Comercio     @relation(fields: [id_comercio], references: [id_comercio])
  usuario          Usuario      @relation(fields: [id_usuario], references: [id_usuario])
  liquidacion      Liquidacion? @relation(fields: [id_liquidacion], references: [id_liquidacion])
  detalles         VentaDetalle[]
  devoluciones     Devolucion[]
  venta_origen     VentaCabecera?  @relation("RectificacionOrigen", fields: [id_venta_origen], references: [id_venta])
  rectificaciones  VentaCabecera[] @relation("RectificacionOrigen")

  @@map("VENTAS_CABECERA")
}

model VentaDetalle {
  id_detalle               String   @id @default(uuid()) @db.Uuid
  id_venta                 String   @db.Uuid
  id_producto              String   @db.Uuid
  cantidad                 Int
  precio_unitario_cobrado    Decimal  @db.Decimal(10, 2)
  precio_pushsport_historico Decimal  @default(0) @db.Decimal(10, 2)
  costo_unitario_historico   Decimal  @db.Decimal(10, 2)
  tiene_variantes          Boolean   @default(false)

  venta                    VentaCabecera @relation(fields: [id_venta], references: [id_venta])
  producto                 Producto      @relation(fields: [id_producto], references: [id_producto])
  variantes                VentaDetalleVariante[]

  @@map("VENTAS_DETALLE")
}

model Liquidacion {
  id_liquidacion     String   @id @default(uuid()) @db.Uuid
  id_comercio        String   @db.Uuid
  fecha_cierre       DateTime @default(now())
  total_ventas_netas Decimal  @db.Decimal(10, 2)
  monto_recibido     Decimal  @db.Decimal(10, 2)
  diferencia         Decimal  @db.Decimal(10, 2)
  observacion        String?  @db.Text
  estado             String

  comercio           Comercio @relation(fields: [id_comercio], references: [id_comercio])
  ventas             VentaCabecera[]

  @@map("LIQUIDACIONES")
}

model AuditoriaSistema {
  id_auditoria        String   @id @default(uuid()) @db.Uuid
  id_usuario          String   @db.Uuid
  
  // Entidad afectada
  entidad_afectada    String   // 'Producto', 'Venta', 'Usuario', etc.
  id_entidad_afectada String?  @db.Uuid  // ID del registro afectado para filtrado
  
  // AcciГғВіn detallada
  accion              String   // 'CREATE', 'UPDATE', 'DELETE', 'LOGIN', 'LOGOUT', etc.
  descripcion_accion  String?  @db.Text  // DescripciГғВіn legible de la acciГғВіn
  
  // Datos JSON completos
  valor_anterior      String?  @db.Text  // @deprecated - usar datos_anteriores
  valor_nuevo         String?  @db.Text  // @deprecated - usar datos_nuevos
  datos_anteriores    String?  @db.Text  // JSON del estado anterior completo
  datos_nuevos        String?  @db.Text  // JSON del estado nuevo completo
  cambios_detectados  String?  @db.Text  // JSON solo con campos cambiados {campo: {antes, despues}}
  
  // Contexto de la operaciГғВіn
  endpoint            String?  // /api/productos/123
  metodo_http         String?  // PUT, POST, DELETE
  ip_usuario          String?  // 192.168.1.100
  user_agent          String?  // Mozilla/5.0...
  
  // IDs relacionados para filtrado (sin FK para evitar bloqueos)
  id_comercio         String?  @db.Uuid  // Para filtrar por sucursal
  id_producto         String?  @db.Uuid  // Para filtrar por producto
  id_variante         String?  @db.Uuid  // Para filtrar por variante
  id_venta            String?  @db.Uuid  // Para filtrar por venta
  id_proveedor        String?  @db.Uuid  // Para filtrar por proveedor
  
  fecha_hora          DateTime @default(now())
  
  usuario             Usuario  @relation(fields: [id_usuario], references: [id_usuario])
  
  @@map("AUDITORIA_SISTEMA")
  @@index([entidad_afectada])
  @@index([id_entidad_afectada])
  @@index([id_usuario])
  @@index([fecha_hora])
  @@index([id_comercio])
  @@index([id_producto])
  @@index([id_venta])
}

model Descuento {
  id_descuento     String   @id @default(uuid()) @db.Uuid
  codigo           String   @unique
  tipo_descuento   String   @default("porcentaje") // "porcentaje" o "fijo"
  valor_descuento  Decimal  @db.Decimal(10, 2)
  usos_actuales    Int      @default(0)
  usos_maximos     Int?
  activo           Boolean  @default(true)
  fecha_creacion   DateTime @default(now())

  @@map("DESCUENTOS")
}

model Oferta {
  id_oferta             String    @id @default(uuid()) @db.Uuid
  nombre                String
  descuento_porcentaje  Decimal   @db.Decimal(5, 2)
  fecha_inicio          DateTime
  fecha_fin             DateTime?
  activo                Boolean   @default(true)
  fecha_creacion        DateTime  @default(now())

  @@map("OFERTAS")
}

model Combo {
  id_combo        String   @id @default(uuid()) @db.Uuid
  nombre          String
  descripcion     String?  @db.Text
  precio_combo    Decimal  @db.Decimal(10, 2)
  activo          Boolean  @default(true)
  fecha_creacion  DateTime @default(now())

  @@map("COMBOS")
}

model Devolucion {
  id_devolucion   Int      @id @default(autoincrement())
  id_venta        String   @db.Uuid
  id_producto     String   @db.Uuid
  cantidad        Int
  monto_reembolso Decimal  @db.Decimal(10, 2)
  motivo          String?  @db.Text
  fecha           DateTime @default(now())
  id_usuario      String   @db.Uuid
  id_comercio     String   @db.Uuid

  venta    VentaCabecera @relation(fields: [id_venta], references: [id_venta])
  producto Producto      @relation(fields: [id_producto], references: [id_producto])
  usuario  Usuario       @relation(fields: [id_usuario], references: [id_usuario])
  comercio Comercio      @relation(fields: [id_comercio], references: [id_comercio])

  @@map("DEVOLUCIONES")
}

model PasswordResetToken {
  id         String   @id @default(uuid()) @db.Uuid
  id_usuario String   @db.Uuid
  token      String   @unique
  expira_en  DateTime
  usado      Boolean  @default(false)
  creado_en  DateTime @default(now())
  
  usuario Usuario @relation(fields: [id_usuario], references: [id_usuario])
  
  @@map("PASSWORD_RESET_TOKENS")
}

